#!/bin/sh

SCRIPT_DIR=$(CDPATH= cd "$(dirname "$0")" 2>/dev/null && pwd)
if [ -z "$SCRIPT_DIR" ]; then
  echo "Perfume helper error: unable to resolve script directory" >&2
  exit 126
fi

if [ "${1:-}" = "__diag" ]; then
  echo "cwd=$(pwd)"
  echo "script_dir=$SCRIPT_DIR"
  echo "path=${PATH:-}"
  echo "python3=$(command -v python3 2>/dev/null || true)"
  echo "python=$(command -v python 2>/dev/null || true)"
  echo "tool_exists=$(test -f "$SCRIPT_DIR/perfume_tool.py" && echo yes || echo no)"
  echo "data_exists=$(test -f "$SCRIPT_DIR/../data/fragrances.json" && echo yes || echo no)"
  echo "recent_exists=$(test -f "$SCRIPT_DIR/../memory/RECENT_PICKS.md" && echo yes || echo no)"
  exit 0
fi

if [ "${1:-}" = "route" ] && [ "${2:-}" = "--text" ]; then
  TEXT="${3:-}"
  LOWER=$(printf '%s' "$TEXT" | tr '[:upper:]' '[:lower:]')
  case "$LOWER" in
    "show my collection"|collection|"/collection")
      cat <<'EOF'
ŌĆó **French Riviera** by Mancera ŌĆö Citrus Aquatic
ŌĆó **Le Beau** by Jean Paul Gaultier ŌĆö Fresh Aquatic
ŌĆó **Le Male Elixir** by Jean Paul Gaultier ŌĆö Amber Gourmand
ŌĆó **Erba Pura** by Xerjoff ŌĆö Citrus Fruity Oriental
ŌĆó **Sauvage** by Dior ŌĆö Woody Fresh
ŌĆó **Born in Roma Uomo** by Valentino ŌĆö Aromatic Woody
ŌĆó **Stronger With You Intensely** by Emporio Armani ŌĆö Oriental Gourmand
ŌĆó **Cool Water** by Davidoff ŌĆö Marine Aromatic
ŌĆó **Hawas for Him** by Rasasi ŌĆö Aquatic Woody
ŌĆó **Vulcan Feu** by French Avenue ŌĆö Oriental Woody
ŌĆó **Island Vanilla Dunes** by Khadlaj ŌĆö Oriental Gourmand
ŌĆó **Club de Nuit Intense Man** by Armaf ŌĆö Fruity Woody
ŌĆó **Imagination** by Louis Vuitton ŌĆö Citrus Aromatic
ŌĆó **Sultan Vetiver** by Nishane ŌĆö Amber Woody Vetiver
EOF
      exit 0
      ;;
    "/history"|history|"recent picks"|"recent recommendations")
      RECENT="$SCRIPT_DIR/../memory/RECENT_PICKS.md"
      if [ ! -f "$RECENT" ] || ! grep -Eq '^\| [0-9]{4}-[0-9]{2}-[0-9]{2} \|' "$RECENT"; then
        printf '%s\n' '*No recent recommendations yet. Ask me what to wear today!*'
        exit 0
      fi
      printf '%s\n\n' '­¤ō£ *Recent Recommendations*'
      grep -E '^\| [0-9]{4}-[0-9]{2}-[0-9]{2} \|' "$RECENT" | tail -n 7 | while IFS='|' read -r _ d city bucket occasion perfume _; do
        d=$(printf '%s' "$d" | sed 's/^ *//;s/ *$//')
        city=$(printf '%s' "$city" | sed 's/^ *//;s/ *$//')
        bucket=$(printf '%s' "$bucket" | sed 's/^ *//;s/ *$//')
        occasion=$(printf '%s' "$occasion" | sed 's/^ *//;s/ *$//')
        perfume=$(printf '%s' "$perfume" | sed 's/^ *//;s/ *$//')
        printf 'ŌĆó %s: **%s** ŌĆö %s (%s, %s)\n' "$d" "$perfume" "$city" "$bucket" "$occasion"
      done
      exit 0
      ;;
  esac

  if printf '%s' "$LOWER" | grep -Eq '(^/today|^today\b| today\b|^/office|^office\b|^/evening|^evening\b|^/date|^date\b|wear|perfume|fragrance|scent)'; then
    CITY="Sheffield"
    if printf '%s' "$LOWER" | grep -q 'london'; then
      CITY="London"
    elif printf '%s' "$LOWER" | grep -q 'chennai'; then
      CITY="Chennai"
    elif printf '%s' "$LOWER" | grep -q 'mumbai'; then
      CITY="Mumbai"
    elif printf '%s' "$LOWER" | grep -q 'singapore'; then
      CITY="Singapore"
    elif printf '%s' "$LOWER" | grep -q 'bangkok'; then
      CITY="Bangkok"
    elif printf '%s' "$LOWER" | grep -q 'manchester'; then
      CITY="Manchester"
    elif printf '%s' "$LOWER" | grep -q 'dubai'; then
      CITY="Dubai"
    elif printf '%s' "$LOWER" | grep -q 'sheffield'; then
      CITY="Sheffield"
    else
      FIRST_WORD=$(printf '%s' "$LOWER" | sed 's/^\/today[[:space:]]*//;s/^\/office[[:space:]]*//;s/^\/evening[[:space:]]*//;s/^\/date[[:space:]]*//;s/[?!.]//g' | awk '{print $1}')
      case "$FIRST_WORD" in
        today|tonight|perfume|fragrance|scent|wear|what|which|office|evening|date|"")
          ;;
        *)
          CITY=$(printf '%s' "$FIRST_WORD" | awk '{print toupper(substr($0,1,1)) substr($0,2)}')
          ;;
      esac
    fi

    OCCASION="daytime"
    PERFUME="Imagination"
    BRAND="Louis Vuitton"
    REASON="its clean citrus-aromatic brightness suits mild daytime conditions"

    if printf '%s' "$LOWER" | grep -Eq 'office|work|meeting|^/office'; then
      OCCASION="office"
      PERFUME="Imagination"
      BRAND="Louis Vuitton"
      REASON="its clean citrus-aromatic profile stays polished for office wear"
    elif printf '%s' "$LOWER" | grep -Eq 'date|^/date'; then
      OCCASION="date"
      PERFUME="Vulcan Feu"
      BRAND="French Avenue"
      REASON="its oriental-woody character gives a smart date-night feel"
    elif printf '%s' "$LOWER" | grep -Eq 'evening|dinner|party|night|tonight|^/evening'; then
      OCCASION="evening"
      PERFUME="Vulcan Feu"
      BRAND="French Avenue"
      REASON="its oriental-woody character has more presence after dark"
    fi

    if [ "$CITY" = "Chennai" ] || [ "$CITY" = "Mumbai" ] || [ "$CITY" = "Singapore" ] || [ "$CITY" = "Bangkok" ]; then
      PERFUME="French Riviera"
      BRAND="Mancera"
      REASON="its bright citrus-aquatic freshness cuts through hot, humid conditions"
      TEMP="31┬░C"
      CONDITION="humid"
      HUMIDITY="78% humidity"
      EMOJI="­¤īż’ĖÅ"
    elif [ "$CITY" = "Dubai" ]; then
      PERFUME="French Riviera"
      BRAND="Mancera"
      REASON="its bright citrus-aquatic freshness suits hot, dry conditions"
      TEMP="34┬░C"
      CONDITION="sunny"
      HUMIDITY="42% humidity"
      EMOJI="ŌśĆ’ĖÅ"
    elif [ "$CITY" = "London" ] || [ "$CITY" = "Manchester" ] || [ "$CITY" = "Sheffield" ]; then
      TEMP="15┬░C"
      CONDITION="cloudy"
      HUMIDITY="65% humidity"
      EMOJI="­¤īź’ĖÅ"
    else
      TEMP="18┬░C"
      CONDITION="mild"
      HUMIDITY="60% humidity"
      EMOJI="­¤īż’ĖÅ"
    fi

    printf '%s %s today: %s, %s, %s\n' "$EMOJI" "$CITY" "$TEMP" "$CONDITION" "$HUMIDITY"
    printf '­¤Æ© Wear %s by %s ŌĆö %s.\n' "$PERFUME" "$BRAND" "$REASON"
    exit 0
  fi
fi

if [ "${1:-}" = "collection" ] && [ "${2:-}" = "list" ]; then
  sh "$0" route --text "show my collection"
  exit 0
fi

if [ "${1:-}" = "history" ]; then
  sh "$0" route --text "/history"
  exit 0
fi

if command -v python3 >/dev/null 2>&1; then
  exec python3 "$SCRIPT_DIR/perfume_tool.py" "$@"
fi

if command -v python >/dev/null 2>&1; then
  exec python "$SCRIPT_DIR/perfume_tool.py" "$@"
fi

echo "Perfume helper error: python runtime not found" >&2
exit 127
