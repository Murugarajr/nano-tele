#!/bin/sh

SCRIPT_DIR=$(CDPATH= cd "$(dirname "$0")" 2>/dev/null && pwd)
if [ -z "$SCRIPT_DIR" ]; then
  echo "Perfume helper error: unable to resolve script directory" >&2
  exit 126
fi

if [ "${1:-}" = "__diag" ]; then
  echo "cwd=$(pwd)"
  echo "script_dir=$SCRIPT_DIR"
  echo "path=${PATH:-}"
  echo "python3=$(command -v python3 2>/dev/null || true)"
  echo "python=$(command -v python 2>/dev/null || true)"
  echo "tool_exists=$(test -f "$SCRIPT_DIR/perfume_tool.py" && echo yes || echo no)"
  echo "data_exists=$(test -f "$SCRIPT_DIR/../data/fragrances.json" && echo yes || echo no)"
  echo "recent_exists=$(test -f "$SCRIPT_DIR/../memory/RECENT_PICKS.md" && echo yes || echo no)"
  exit 0
fi

brand_for_perfume() {
  case "$1" in
    "French Riviera") printf '%s\n' "Mancera" ;;
    "Le Beau"|"Le Male Elixir") printf '%s\n' "Jean Paul Gaultier" ;;
    "Erba Pura") printf '%s\n' "Xerjoff" ;;
    "Sauvage") printf '%s\n' "Dior" ;;
    "Born in Roma Uomo") printf '%s\n' "Valentino" ;;
    "Stronger With You Intensely") printf '%s\n' "Emporio Armani" ;;
    "Cool Water") printf '%s\n' "Davidoff" ;;
    "Hawas for Him") printf '%s\n' "Rasasi" ;;
    "Vulcan Feu") printf '%s\n' "French Avenue" ;;
    "Island Vanilla Dunes") printf '%s\n' "Khadlaj" ;;
    "Club de Nuit Intense Man") printf '%s\n' "Armaf" ;;
    "Imagination") printf '%s\n' "Louis Vuitton" ;;
    "Sultan Vetiver") printf '%s\n' "Nishane" ;;
    *) printf '%s\n' "" ;;
  esac
}

reason_for_perfume() {
  case "$1:$2:$3" in
    "French Riviera:Hot & humid:"*) printf '%s\n' "its bright citrus-aquatic freshness cuts through hot, humid conditions" ;;
    "French Riviera:Hot & dry:"*) printf '%s\n' "its bright citrus-aquatic freshness suits hot, dry conditions" ;;
    "Sultan Vetiver:Cold & rainy:"*) printf '%s\n' "its warm amber-woody vetiver character suits cool, wet conditions" ;;
    "Vulcan Feu:"*"date"*) printf '%s\n' "its oriental-woody character gives a smart date-night feel" ;;
    "Vulcan Feu:"*) printf '%s\n' "its oriental-woody character has more presence after dark" ;;
    "Imagination:"*"office"*) printf '%s\n' "its clean citrus-aromatic profile stays polished for office wear" ;;
    "Imagination:"*) printf '%s\n' "its clean citrus-aromatic brightness suits mild daytime conditions" ;;
    "Le Beau:"*) printf '%s\n' "its fresh aquatic sweetness works well when conditions are warm and humid" ;;
    "Cool Water:"*) printf '%s\n' "its crisp marine freshness is easy to wear in humid weather" ;;
    "Hawas for Him:"*) printf '%s\n' "its aquatic woody freshness carries well in warm conditions" ;;
    "Sauvage:"*) printf '%s\n' "its clean woody freshness is a reliable alternative for mild weather" ;;
    "Born in Roma Uomo:"*) printf '%s\n' "its aromatic woody profile gives a polished mild-weather alternative" ;;
    "Le Male Elixir:"*) printf '%s\n' "its warm amber-gourmand depth suits cold or wet conditions" ;;
    "Island Vanilla Dunes:"*) printf '%s\n' "its soft oriental-gourmand warmth fits cold weather" ;;
    "Stronger With You Intensely:"*) printf '%s\n' "its warm gourmand character works well after dark in cool weather" ;;
    "Club de Nuit Intense Man:"*) printf '%s\n' "its fruity woody profile adds presence for evening wear" ;;
    "Erba Pura:"*) printf '%s\n' "its bright fruity-oriental profile gives stronger projection in warm weather" ;;
    *) printf '%s\n' "it fits today's weather and occasion better than repeating yesterday's pick" ;;
  esac
}

candidates_for_bucket() {
  case "$1:$2" in
    "Hot & humid:office") printf '%s\n' "French Riviera" "Cool Water" "Hawas for Him" "Le Beau" ;;
    "Hot & humid:evening") printf '%s\n' "Le Beau" "French Riviera" "Hawas for Him" "Cool Water" ;;
    "Hot & humid:date") printf '%s\n' "Le Beau" "French Riviera" "Hawas for Him" ;;
    "Hot & humid:"*) printf '%s\n' "French Riviera" "Le Beau" "Cool Water" "Hawas for Him" ;;
    "Hot & dry:office") printf '%s\n' "Imagination" "French Riviera" "Cool Water" "Hawas for Him" ;;
    "Hot & dry:evening") printf '%s\n' "Erba Pura" "Imagination" "Hawas for Him" "French Riviera" "Cool Water" ;;
    "Hot & dry:date") printf '%s\n' "Erba Pura" "Imagination" "Hawas for Him" "French Riviera" ;;
    "Hot & dry:"*) printf '%s\n' "French Riviera" "Imagination" "Cool Water" "Hawas for Him" "Erba Pura" ;;
    "Cold & rainy:evening"|"Cold & rainy:date") printf '%s\n' "Le Male Elixir" "Island Vanilla Dunes" "Sultan Vetiver" ;;
    "Cold & rainy:"*) printf '%s\n' "Sultan Vetiver" "Le Male Elixir" "Island Vanilla Dunes" ;;
    "Mild:office") printf '%s\n' "Imagination" "Born in Roma Uomo" "Sauvage" "Club de Nuit Intense Man" ;;
    "Mild:evening") printf '%s\n' "Vulcan Feu" "Club de Nuit Intense Man" "Erba Pura" "Born in Roma Uomo" "Sauvage" ;;
    "Mild:date") printf '%s\n' "Vulcan Feu" "Club de Nuit Intense Man" "Erba Pura" "Born in Roma Uomo" ;;
    "Mild:"*) printf '%s\n' "Imagination" "Sauvage" "Born in Roma Uomo" "French Riviera" "Erba Pura" ;;
    *) printf '%s\n' "Imagination" "Sauvage" "Born in Roma Uomo" "French Riviera" ;;
  esac
}

was_used_yesterday() {
  RECENT="$SCRIPT_DIR/../memory/RECENT_PICKS.md"
  [ -n "${YESTERDAY:-}" ] || return 1
  [ -f "$RECENT" ] || return 1
  grep -E "^\| $YESTERDAY \|" "$RECENT" | awk -F'|' '{gsub(/^ *| *$/,"",$6); print $6}' | grep -Fxq "$1"
}

choose_rotated_perfume() {
  if ! was_used_yesterday "$PERFUME"; then
    return 0
  fi
  CANDIDATE=$(candidates_for_bucket "$BUCKET" "$OCCASION" | while IFS= read -r name; do
    if ! was_used_yesterday "$name"; then
      printf '%s\n' "$name"
      break
    fi
  done)
  if [ -n "$CANDIDATE" ]; then
    PERFUME="$CANDIDATE"
    BRAND=$(brand_for_perfume "$PERFUME")
    REASON=$(reason_for_perfume "$PERFUME" "$BUCKET" "$OCCASION")
  fi
}

append_recent_pick() {
  RECENT="$SCRIPT_DIR/../memory/RECENT_PICKS.md"
  TODAY=$(date -u +%F 2>/dev/null || date +%F)
  mkdir -p "$SCRIPT_DIR/../memory" 2>/dev/null || true
  if [ ! -f "$RECENT" ]; then
    cat > "$RECENT" <<'EOF'
# Recent Perfume Recommendations Log

| Date | City | Weather Bucket | Occasion | Perfume |
|------|------|----------------|----------|---------|
EOF
  fi
  printf '| %s | %s | %s | %s | %s |\n' "$TODAY" "$CITY" "$BUCKET" "$OCCASION" "$PERFUME" >> "$RECENT"
}

title_case_city() {
  upper=$(printf '%s' "$1" | tr '[:lower:]' '[:upper:]')
  if printf '%s' "${TEXT:-}" | grep -Eq "(^|[^[:alpha:]])$upper([^[:alpha:]]|$)"; then
    printf '%s\n' "$upper"
    return 0
  fi
  printf '%s' "$1" | awk '{for (i=1; i<=NF; i++) $i=toupper(substr($i,1,1)) substr($i,2)} 1'
}

clean_city_candidate() {
  printf '%s' "$1" |
    sed "s/[?!.]//g;s/^ *//;s/ *$//;s/[[:space:]]\\+/ /g" |
    sed "s/for a party.*//;s/for party.*//;s/for office.*//;s/for work.*//;s/for date.*//;s/with friends//;s/to go out//" |
    sed "s/today//g;s/tomorrow//g;s/tonight//g;s/now//g;s/daytime//g;s/evening//g;s/^in //;s/^at //;s/^ *//;s/ *$//;s/[[:space:]]\\+/ /g"
}

extract_city() {
  cleaned=$(printf '%s' "$LOWER" | sed "s/[?!.]//g;s/[[:space:]]\\+/ /g;s/^ *//;s/ *$//")

  candidate=$(printf '%s' "$cleaned" | sed -n "s/.*[[:space:]]in[[:space:]]\\{1,\\}\\([a-z][a-z .'-]*\\)[[:space:]]\\{1,\\}\\(today\\|tomorrow\\|tonight\\|now\\|for\\|at\\|to\\|with\\).*$/\\1/p;s/^in[[:space:]]\\{1,\\}\\([a-z][a-z .'-]*\\)[[:space:]]\\{1,\\}\\(today\\|tomorrow\\|tonight\\|now\\|for\\|at\\|to\\|with\\).*$/\\1/p;s/.*[[:space:]]in[[:space:]]\\{1,\\}\\([a-z][a-z .'-]*\\)$/\\1/p;s/^in[[:space:]]\\{1,\\}\\([a-z][a-z .'-]*\\)$/\\1/p" | head -n 1)
  candidate=$(clean_city_candidate "$candidate")
  if [ -n "$candidate" ]; then
    title_case_city "$candidate"
    return 0
  fi

  candidate=""
  case "$cleaned" in
    /today\ *|/office\ *|/evening\ *|/date\ *)
      candidate=$(printf '%s' "$cleaned" | sed 's#^/[a-z][a-z]*[[:space:]]*##')
      ;;
    today\ *|tomorrow\ *|office\ *|evening\ *|date\ *)
      candidate=$(printf '%s' "$cleaned" | sed 's#^[a-z][a-z]*[[:space:]]*##')
      ;;
  esac
  candidate=$(clean_city_candidate "$candidate")
  if [ -n "$candidate" ]; then
    title_case_city "$candidate"
    return 0
  fi

  candidate=$(printf '%s' "$cleaned" | sed -n "s/^\/\\(today\\|office\\|evening\\|date\\)[[:space:]]\\{1,\\}\\([a-z][a-z .'-]*\\)$/\\2/p;s/^\\(today\\|tomorrow\\|office\\|evening\\|date\\)[[:space:]]\\{1,\\}\\([a-z][a-z .'-]*\\)$/\\2/p" | head -n 1)
  candidate=$(clean_city_candidate "$candidate")
  if [ -n "$candidate" ]; then
    title_case_city "$candidate"
    return 0
  fi

  candidate=$(printf '%s' "$cleaned" | sed -n "s/^\\([a-z][a-z .'-]*\\)[[:space:]]\\{1,\\}\\(today\\|tomorrow\\|tonight\\|now\\)$/\\1/p" | head -n 1)
  candidate=$(clean_city_candidate "$candidate")
  if [ -n "$candidate" ]; then
    title_case_city "$candidate"
    return 0
  fi

  candidate=$(printf '%s' "$cleaned" | sed "s/^what should i wear[[:space:]]*//;s/^what perfume should i wear[[:space:]]*//;s/^which perfume should i wear[[:space:]]*//;s/^perfume to wear[[:space:]]*//;s/^fragrance to wear[[:space:]]*//;s/^scent to wear[[:space:]]*//;s/^wear[[:space:]]*//")
  candidate=$(clean_city_candidate "$candidate")
  case "$candidate" in
    ""|"today"|"tomorrow"|"tonight"|"perfume"|"fragrance"|"scent"|"what"|"which"|"office"|"evening"|"date"|"work"|"meeting")
      ;;
    *)
      title_case_city "$candidate"
      return 0
      ;;
  esac

  printf '%s\n' "Sheffield"
}

if [ "${1:-}" = "route" ] && [ "${2:-}" = "--text" ]; then
  TEXT="${3:-}"
  LOWER=$(printf '%s' "$TEXT" | tr '[:upper:]' '[:lower:]')
  case "$LOWER" in
    "show my collection"|collection|"/collection")
      cat <<'EOF'
• **French Riviera** by Mancera — Citrus Aquatic
• **Le Beau** by Jean Paul Gaultier — Fresh Aquatic
• **Le Male Elixir** by Jean Paul Gaultier — Amber Gourmand
• **Erba Pura** by Xerjoff — Citrus Fruity Oriental
• **Sauvage** by Dior — Woody Fresh
• **Born in Roma Uomo** by Valentino — Aromatic Woody
• **Stronger With You Intensely** by Emporio Armani — Oriental Gourmand
• **Cool Water** by Davidoff — Marine Aromatic
• **Hawas for Him** by Rasasi — Aquatic Woody
• **Vulcan Feu** by French Avenue — Oriental Woody
• **Island Vanilla Dunes** by Khadlaj — Oriental Gourmand
• **Club de Nuit Intense Man** by Armaf — Fruity Woody
• **Imagination** by Louis Vuitton — Citrus Aromatic
• **Sultan Vetiver** by Nishane — Amber Woody Vetiver
EOF
      exit 0
      ;;
    "/history"|history|"recent picks"|"recent recommendations")
      RECENT="$SCRIPT_DIR/../memory/RECENT_PICKS.md"
      if [ ! -f "$RECENT" ] || ! grep -Eq '^\| [0-9]{4}-[0-9]{2}-[0-9]{2} \|' "$RECENT"; then
        printf '%s\n' '*No recent recommendations yet. Ask me what to wear today!*'
        exit 0
      fi
      printf '%s\n\n' '📜 *Recent Recommendations*'
      grep -E '^\| [0-9]{4}-[0-9]{2}-[0-9]{2} \|' "$RECENT" | tail -n 7 | while IFS='|' read -r _ d city bucket occasion perfume _; do
        d=$(printf '%s' "$d" | sed 's/^ *//;s/ *$//')
        city=$(printf '%s' "$city" | sed 's/^ *//;s/ *$//')
        bucket=$(printf '%s' "$bucket" | sed 's/^ *//;s/ *$//')
        occasion=$(printf '%s' "$occasion" | sed 's/^ *//;s/ *$//')
        perfume=$(printf '%s' "$perfume" | sed 's/^ *//;s/ *$//')
        printf '• %s: **%s** — %s (%s, %s)\n' "$d" "$perfume" "$city" "$bucket" "$occasion"
      done
      exit 0
      ;;
  esac

  if printf '%s' "$LOWER" | grep -Eq '(^/today|^today\b| today\b|^tomorrow\b| tomorrow\b|^now\b| now\b|^/office|^office\b|^/evening|^evening\b|^/date|^date\b|wear|perfume|fragrance|scent)'; then
    CITY=$(extract_city)

    DAY_LABEL="today"
    WEATHER_INDEX=0
    if printf '%s' "$LOWER" | grep -q 'tomorrow'; then
      DAY_LABEL="tomorrow"
      WEATHER_INDEX=1
    fi

    OCCASION="daytime"
    PERFUME="Imagination"
    BRAND="Louis Vuitton"
    REASON="its clean citrus-aromatic brightness suits mild daytime conditions"
    YESTERDAY=$(date -u -v-1d +%F 2>/dev/null || date -u -d yesterday +%F 2>/dev/null || true)

    if printf '%s' "$LOWER" | grep -Eq 'office|work|meeting|^/office'; then
      OCCASION="office"
      PERFUME="Imagination"
      BRAND="Louis Vuitton"
      REASON="its clean citrus-aromatic profile stays polished for office wear"
    elif printf '%s' "$LOWER" | grep -Eq 'date|^/date'; then
      OCCASION="date"
      PERFUME="Vulcan Feu"
      BRAND="French Avenue"
      REASON="its oriental-woody character gives a smart date-night feel"
    elif printf '%s' "$LOWER" | grep -Eq 'evening|dinner|party|night|tonight|^/evening'; then
      OCCASION="evening"
      PERFUME="Vulcan Feu"
      BRAND="French Avenue"
      REASON="its oriental-woody character has more presence after dark"
    fi

    LIVE_WEATHER=""
    if command -v curl >/dev/null 2>&1; then
      WTTR_CITY=$(printf '%s' "$CITY" | sed 's/ /+/g')
      if [ "$WEATHER_INDEX" -eq 0 ]; then
        LIVE_WEATHER=$(curl -fsS --max-time 6 "https://wttr.in/${WTTR_CITY}?format=%t|%C|%h" 2>/dev/null || true)
      elif command -v python3 >/dev/null 2>&1; then
        LIVE_WEATHER=$(curl -fsS --max-time 8 "https://wttr.in/${WTTR_CITY}?format=j1" 2>/dev/null | python3 -c 'import json,sys
data=json.load(sys.stdin)
weather=data.get("weather") or []
if len(weather) < 2:
    raise SystemExit(1)
day=weather[1]
hourly=day.get("hourly") or []
hour=hourly[4] if len(hourly) > 4 else (hourly[len(hourly)//2] if hourly else {})
desc=((hour.get("weatherDesc") or [{}])[0].get("value") or "").strip()
temp=(day.get("avgtempC") or "").strip()
humidity=(hour.get("humidity") or "").strip()
if not temp or not desc or not humidity:
    raise SystemExit(1)
print(f"{temp}°C|{desc}|{humidity}%")
' 2>/dev/null || true)
      fi
    fi

    if ! printf '%s' "$LIVE_WEATHER" | grep -q '|'; then
      printf 'Live weather is unavailable for %s %s, so I cannot make a weather-based recommendation.\n' "$CITY" "$DAY_LABEL"
      exit 0
    fi

    TEMP=$(printf '%s' "$LIVE_WEATHER" | awk -F'|' '{print $1}' | sed 's/^+//;s/^ *//;s/ *$//')
    CONDITION=$(printf '%s' "$LIVE_WEATHER" | awk -F'|' '{print $2}' | sed 's/^ *//;s/ *$//')
    HUMIDITY_RAW=$(printf '%s' "$LIVE_WEATHER" | awk -F'|' '{print $3}' | sed 's/^ *//;s/ *$//')
    HUMIDITY="${HUMIDITY_RAW} humidity"

    TEMP_NUM=$(printf '%s' "$TEMP" | sed 's/°C//;s/[^0-9-]//g')
    HUMIDITY_NUM=$(printf '%s' "$HUMIDITY_RAW" | sed 's/[^0-9]//g')
    CONDITION_LOWER=$(printf '%s' "$CONDITION" | tr '[:upper:]' '[:lower:]')

    if [ -z "$TEMP_NUM" ] || [ -z "$HUMIDITY_NUM" ] || [ -z "$CONDITION" ]; then
      printf 'Live weather is unavailable for %s %s, so I cannot make a weather-based recommendation.\n' "$CITY" "$DAY_LABEL"
      exit 0
    fi

    EMOJI="🌤️"
    if printf '%s' "$CONDITION_LOWER" | grep -Eq 'rain|drizzle|shower'; then
      EMOJI="🌧️"
    elif printf '%s' "$CONDITION_LOWER" | grep -Eq 'sun|clear'; then
      EMOJI="☀️"
    elif printf '%s' "$CONDITION_LOWER" | grep -Eq 'cloud|overcast'; then
      EMOJI="🌥️"
    elif printf '%s' "$CONDITION_LOWER" | grep -Eq 'mist|fog|haze'; then
      EMOJI="🌫️"
    fi

    if [ "$TEMP_NUM" -gt 25 ] && [ "$HUMIDITY_NUM" -ge 50 ]; then
      BUCKET="Hot & humid"
      PERFUME="French Riviera"
      BRAND="Mancera"
      REASON="its bright citrus-aquatic freshness cuts through hot, humid conditions"
    elif [ "$TEMP_NUM" -gt 25 ]; then
      BUCKET="Hot & dry"
      PERFUME="French Riviera"
      BRAND="Mancera"
      REASON="its bright citrus-aquatic freshness suits hot, dry conditions"
    elif [ "$TEMP_NUM" -lt 15 ] && { [ "$HUMIDITY_NUM" -ge 70 ] || printf '%s' "$CONDITION_LOWER" | grep -Eq 'rain|drizzle|shower'; }; then
      BUCKET="Cold & rainy"
      PERFUME="Sultan Vetiver"
      BRAND="Nishane"
      REASON="its warm amber-woody vetiver character suits cool, wet conditions"
    else
      BUCKET="Mild"
    fi

    if [ "$BUCKET" = "Mild" ] && [ "$OCCASION" = "office" ]; then
      PERFUME="Imagination"
      BRAND="Louis Vuitton"
      REASON="its clean citrus-aromatic profile stays polished for office wear"
    elif [ "$BUCKET" = "Mild" ] && [ "$OCCASION" = "date" ]; then
      PERFUME="Vulcan Feu"
      BRAND="French Avenue"
      REASON="its oriental-woody character gives a smart date-night feel"
    elif [ "$BUCKET" = "Mild" ] && [ "$OCCASION" = "evening" ]; then
      PERFUME="Vulcan Feu"
      BRAND="French Avenue"
      REASON="its oriental-woody character has more presence after dark"
    fi

    choose_rotated_perfume
    printf '%s %s %s: %s, %s, %s\n' "$EMOJI" "$CITY" "$DAY_LABEL" "$TEMP" "$CONDITION" "$HUMIDITY"
    printf '💨 Wear %s by %s — %s.\n' "$PERFUME" "$BRAND" "$REASON"
    append_recent_pick
    exit 0
  fi
fi

if [ "${1:-}" = "collection" ] && [ "${2:-}" = "list" ]; then
  sh "$0" route --text "show my collection"
  exit 0
fi

if [ "${1:-}" = "history" ]; then
  sh "$0" route --text "/history"
  exit 0
fi

if command -v python3 >/dev/null 2>&1; then
  exec python3 "$SCRIPT_DIR/perfume_tool.py" "$@"
fi

if command -v python >/dev/null 2>&1; then
  exec python "$SCRIPT_DIR/perfume_tool.py" "$@"
fi

echo "Perfume helper error: python runtime not found" >&2
exit 127
