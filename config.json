{
  "agents": {
    "defaults": {
      "workspace": "./workspace",
      "model": "openai/gpt-oss-20b",
      "provider": "openrouter",
      "maxTokens": 2048,
      "contextWindowTokens": 8192,
      "contextBlockLimit": null,
      "temperature": 0.2,
      "maxToolIterations": 8,
      "maxToolResultChars": 2000,
      "providerRetryMode": "standard",
      "reasoningEffort": null,
      "timezone": "Europe/London",
      "dream": {
        "intervalH": 2,
        "modelOverride": "openrouter/free",
        "maxBatchSize": 30,
        "maxIterations": 10
      }
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "token": "${TELEGRAM_BOT_TOKEN}",
      "allowFrom": ["${ALLOW_FROM}", "${ALLOW_FROM_2}"],
      "proxy": null,
      "replyToMessage": false,
      "reactEmoji": "👀",
      "groupPolicy": "mention",
      "connectionPoolSize": 32,
      "poolTimeout": 5.0,
      "streaming": true
    }
  },
  "providers": {
    "openrouter": {
      "apiKey": "${OR_API_KEY}"
    }
  },
  "api": {
    "host": "127.0.0.1",
    "port": 8900,
    "timeout": 120.0
  },
  "gateway": {
    "host": "0.0.0.0",
    "port": 18790,
    "heartbeat": {
      "enabled": true,
      "intervalS": 21600,
      "keepRecentMessages": 8
    }
  },
  "tools": {
    "web": {
      "enable": true,
      "proxy": null,
      "search": {
        "provider": "duckduckgo",
        "apiKey": "",
        "baseUrl": "",
        "maxResults": 1,
        "timeout": 30
      }
    },
    "exec": {
      "enable": true,
      "timeout": 60,
      "pathAppend": "",
      "sandbox": ""
    },
    "restrictToWorkspace": true,
    "mcpServers": {},
    "ssrfWhitelist": []
  }
}
